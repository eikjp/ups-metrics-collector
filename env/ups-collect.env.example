#example
INFLUX_URL=https://ap-northeast-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=your-write-token-here
INFLUX_ORG=your-org-name
INFLUX_BUCKET=ups
UPS_HOST=ups@localhost       # COLLECT_UPS=false の場合は設定不要
HOST_NAME=your-hostname
HOST_ROLE=ups_monitor
# UPSメトリクス収集の有効/無効（デフォルト: true）
# UPS非接続ホストでホストメトリクスのみ収集する場合は false に設定する
COLLECT_UPS=true
